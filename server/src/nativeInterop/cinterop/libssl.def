#sudo apt-get install libssl-dev
headers = hmac.h evp.h
headerFilter = *
linkerOpts.linux = -lcrypto

# `dpkg-query -L libssl-dev`
compilerOpts.linux = -I/usr/include -I/usr/include/openssl

# `dpkg-query -L libssl-dev`
linkerOpts.linux = -lssl
#dpkg-query -L libssl-dev

# brew install openssl@3
compilerOpts.macos_arm64 = -I/opt/homebrew/opt/openssl@3/include -I/opt/homebrew/opt/openssl@3/include/openssl
linkerOpts.macos_arm64 = -L/opt/homebrew/opt/openssl@3/lib -lssl -lcrypto

compilerOpts.macos_x64 = -I/usr/local/opt/openssl@3/include -I/usr/local/opt/openssl@3/include/openssl
linkerOpts.macos_x64 = -L/usr/local/opt/openssl@3/lib -lssl -lcrypto
